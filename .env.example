# AI Provider Configuration
# Set ONE of the following API keys. The first one found is used.
# Priority: Gemini > OpenAI > Anthropic
# If none are set, the app runs in dev mode with simulated responses.

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
